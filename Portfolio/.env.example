# Configuration SMTP pour le formulaire de contact
# Copiez ce fichier et renommez-le en .env.local pour les tests locaux (NE PAS commiter .env.local)

# Serveur SMTP (ex: smtp.gmail.com pour Gmail, smtp.mailjet.com, etc.)
SMTP_HOST=smtp.gmail.com

# Port SMTP (587 pour TLS/STARTTLS, 465 pour SSL)
SMTP_PORT=587

# Votre identifiant / adresse email SMTP
SMTP_USER=votre-email@gmail.com

# Votre mot de passe SMTP ou Mot de passe d'application (App Password)
# IMPORTANT: Pour Gmail, générez un "Mot de passe d'application" dans la sécurité de votre compte Google.
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# L'adresse email de réception (celle sur laquelle vous recevrez les messages)
CONTACT_TO=destinataire@email.com

# Optionnel : L'adresse email d'envoi affichée (par défaut SMTP_USER si non spécifiée)
CONTACT_FROM=votre-email@gmail.com
